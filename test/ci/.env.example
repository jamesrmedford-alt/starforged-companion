# Copy this file to .env and fill in your foundryvtt.com credentials.
# .env is gitignored — never commit real credentials.
#
# These are consumed by docker-compose.yml and passed to the felddy/foundryvtt
# image, which uses FOUNDRY_USERNAME / FOUNDRY_PASSWORD to download the
# Foundry zip on first boot and verify the license on subsequent boots.

# foundryvtt.com account username (email or username, whichever you log in with)
FOUNDRY_USERNAME=your-foundry-username

# foundryvtt.com account password
FOUNDRY_PASSWORD=your-foundry-password

# Admin password for the running server (Foundry "Setup" / "Configuration"
# screens). Pick anything — this is a dev-only value, not your foundry
# account password. Default suggestion below; change if you like.
FOUNDRY_ADMIN_KEY=atropos-dev
